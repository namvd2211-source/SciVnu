{
  "name": "sci-vnucea-research-assistant",
  "private": true,
  "version": "1.0.0",
  "description": "Firebase-ready frontend and deployment tooling for the AI-Agentic Research Assistant.",
  "scripts": {
    "firebase:login": "firebase login",
    "firebase:use": "firebase use sci-vnucea",
    "firebase:serve": "firebase emulators:start --only hosting",
    "firebase:deploy": "firebase deploy --only hosting",
    "firebase:deploy:all": "firebase deploy",
    "companion:build": "powershell -ExecutionPolicy Bypass -File .\\build_companion_exe.ps1 -BuildMode onedir",
    "companion:installer": "powershell -ExecutionPolicy Bypass -File .\\build_companion_nsis_setup.ps1",
    "release:prepare": "powershell -ExecutionPolicy Bypass -File .\\prepare_github_release.ps1"
  }
}
